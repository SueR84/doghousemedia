---
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Doghouse Media — Web & Video, Dublin",
  description = "An independent, female-owned web & video studio based in Dublin, Ireland. We build websites and shoot film that get good brands noticed.",
} = Astro.props;
---

<!doctype html>
<html lang="en-GB">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/assets/doghouse-mark.svg" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#FAF7F0" />
    <title>{title}</title>
  </head>
  <body>
    <slot />
  </body>
</html>
