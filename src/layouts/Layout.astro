---
import "../styles/global.css";
import StartProjectModal from "../components/StartProjectModal.astro";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Doghouse Media — Web & Video, Dublin",
  description = "An independent, female-owned web & video studio based in Dublin, Ireland. We build websites and shoot film that get good brands noticed.",
} = Astro.props;
---

<!doctype html>
<html lang="en-GB">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/assets/doghouse-mark.svg" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#FAF7F0" />
    <title>{title}</title>
  </head>
  <body>
    <slot />
    <StartProjectModal />

    <script>
      // Lenis smooth scroll — site-wide eased / inertial scrolling.
      // Skipped when the user prefers reduced motion.
      import Lenis from "lenis";
      import "lenis/dist/lenis.css";

      const reduce =
        window.matchMedia &&
        window.matchMedia("(prefers-reduced-motion: reduce)").matches;

      if (!reduce) {
        const lenis = new Lenis({
          duration: 1.1,
          easing: (t: number) => 1 - Math.pow(1 - t, 3), // easeOutCubic
          smoothWheel: true,
        });

        function raf(time: number) {
          lenis.raf(time);
          requestAnimationFrame(raf);
        }
        requestAnimationFrame(raf);
      }
    </script>
  </body>
</html>
