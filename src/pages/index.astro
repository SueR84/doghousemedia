---
import { getCollection } from "astro:content";
import Layout from "../layouts/Layout.astro";
import Nav from "../components/Nav.astro";
import Mark from "../components/Mark.astro";
import Footer from "../components/Footer.astro";

const clients = [
  "Boston Scientific",
  "Amgen",
  "UCD",
  "Irish Research Council",
  "Coroflo",
  "Real Nation",
];

const allProjects = await getCollection("projects", ({ data }) => data.status === "publish");

// Scroll-reactive marquee — two drifting rows of project thumbnails
const withImages = allProjects.filter((p) => p.data.projectImage);
const mqHalf = Math.ceil(withImages.length / 2);
const rowA = withImages.slice(0, mqHalf);
const rowB = withImages.slice(mqHalf);
---

<Layout>
  <Nav />

  <!-- Hero -->
  <header class="hero">
    <div class="wrap">
      <div class="eyebrow">Web + Video · Dublin</div>
      <h1>
        <span class="w" style="animation-delay:.2s">We build </span><span
          class="w"
          style="animation-delay:.3s"><span class="punch blue">websites</span></span
        ><span class="w" style="animation-delay:.4s"> and shoot </span><span
          class="w"
          style="animation-delay:.5s"><span class="punch punch-2 red">film</span></span
        ><span class="w" style="animation-delay:.6s"> that get good brands noticed.</span>
      </h1>
      <p class="hero-sub">
        An independent, female-owned studio. Two crafts, one roof — from MedTech to
        charity to the brands you'd recognise.
      </p>
      <div class="hero-actions">
        <a href="#work" class="btn btn-primary">See the work</a>
        <a href="#contact" class="btn btn-ghost">Talk to us</a>
      </div>
    </div>
    <Mark animated={true} class="hero-mark" />
  </header>

  <!-- Trust ticker -->
  <section class="trust">
    <div class="wrap">
      <div class="trust-label">Trusted by</div>
      <div class="marquee">
        <div class="marquee-track">
          {
            [0, 1].map(() => (
              <div class="marquee-item">
                {clients.map((c) => (
                  <>
                    <span>{c}</span>
                    <i class="dot" />
                  </>
                ))}
              </div>
            ))
          }
        </div>
      </div>
    </div>
  </section>

  <!-- Services / rooms -->
  <section class="rooms" id="services">
    <div class="wrap">
      <div class="kicker">What we do</div>

      <div class="room flip room-band reveal" id="video">
        <div class="room-text">
          <span class="room-tag">Video · Production</span>
          <h3>Film that earns attention</h3>
          <p class="room-body">
            From strategy to final grade. Brand films, event coverage, and the short,
            sharp promos that stop the scroll. Full crew or a nimble two-person unit,
            whatever the job needs.
          </p>
          <a href="/media-production/" class="room-link">Explore video →</a>
        </div>
        <div class="room-visual video"></div>
      </div>

      <div class="room reveal" id="web">
        <div class="room-text">
          <span class="room-tag blue">Web · Development</span>
          <h3>Sites built to last, and to be found</h3>
          <p class="room-body">
            Considered, fast, accessible websites on WordPress or modern static builds.
            Plus the care plans that keep them secure, quick and climbing the rankings
            long after launch.
          </p>
          <a href="/web-development/" class="room-link">Explore web →</a>
        </div>
        <div class="room-visual web-mock" aria-hidden="true">
          <div class="bm-bar">
            <span class="bm-dot"></span><span class="bm-dot"></span><span class="bm-dot"></span>
            <span class="bm-url">doghousemedia.ie</span>
          </div>
          <div class="bm-body">
            <div class="bm-score">
              <svg viewBox="0 0 36 36" class="bm-ring">
                <circle cx="18" cy="18" r="16" class="bm-ring-bg"></circle>
                <circle cx="18" cy="18" r="16" class="bm-ring-fg"></circle>
              </svg>
              <span class="bm-num">100</span>
            </div>
            <ul class="bm-metrics">
              <li>Performance</li>
              <li>Accessibility</li>
              <li>SEO</li>
            </ul>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Work grid -->
  <section class="work" id="work">
    <div class="wrap">
      <div class="work-head reveal">
        <h2>A few we're proud of</h2>
        <a href="/work/">All work →</a>
      </div>
    </div>

    <!-- Scroll-reactive carousel -->
    <div class="home-marquee" id="reel" aria-label="Project reel">
      <div class="mq-row" data-dir="1">
        <div class="mq-track">
          {
            [0, 1, 2].map(() =>
              rowA.map((p) => (
                <a href={`/work/${p.id}/`} class="mq-tile" aria-label={p.data.title}>
                  <img src={p.data.projectImage} alt={p.data.title} loading="lazy" />
                </a>
              ))
            )
          }
        </div>
      </div>
      <div class="mq-row" data-dir="-1">
        <div class="mq-track">
          {
            [0, 1, 2].map(() =>
              rowB.map((p) => (
                <a href={`/work/${p.id}/`} class="mq-tile" aria-label={p.data.title}>
                  <img src={p.data.projectImage} alt={p.data.title} loading="lazy" />
                </a>
              ))
            )
          }
        </div>
      </div>
    </div>
  </section>

  <!-- CTA band -->
  <section class="wrap cta-wrap" id="about">
    <div class="cta reveal">
      <div class="cta-inner">
        <h2>Got something you want to <span class="red">get off the ground?</span></h2>
        <p>Tell us the idea. We'll tell you straight whether we're the right studio for it.</p>
        <a href="mailto:susan@doghousemedia.ie" class="btn btn-cream">Start a project</a>
      </div>
    </div>
  </section>

  <Footer />
</Layout>

<style>
  /* Web room — browser-window performance mockup */
  .web-mock {
    background: #fff !important;
    display: flex !important;
    flex-direction: column;
    padding: 0 !important;
    overflow: hidden;
  }
  .web-mock .bm-bar {
    display: flex;
    align-items: center;
    gap: 7px;
    padding: 12px 16px;
    border-bottom: 1px solid var(--line);
    background: var(--cream);
  }
  .web-mock .bm-dot {
    width: 9px;
    height: 9px;
    border-radius: 50%;
    background: var(--line);
  }
  .web-mock .bm-url {
    margin-left: 10px;
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: 0.04em;
    color: var(--gray);
  }
  .web-mock .bm-body {
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 28px;
    padding: 24px;
  }
  .web-mock .bm-score {
    position: relative;
    width: 104px;
    height: 104px;
    flex: none;
  }
  .web-mock .bm-ring {
    width: 100%;
    height: 100%;
    transform: rotate(-90deg);
  }
  .web-mock .bm-ring-bg {
    fill: none;
    stroke: var(--line);
    stroke-width: 3;
  }
  .web-mock .bm-ring-fg {
    fill: none;
    stroke: var(--teal);
    stroke-width: 3;
    stroke-linecap: round;
    stroke-dasharray: 100.5 100.5;
    stroke-dashoffset: 100.5;
    animation: bm-fill 1.6s var(--ease-rise) forwards;
  }
  @keyframes bm-fill {
    to { stroke-dashoffset: 0; }
  }
  .web-mock .bm-num {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--disp);
    font-weight: 800;
    font-size: 30px;
    letter-spacing: -0.03em;
    color: var(--teal);
  }
  .web-mock .bm-metrics {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }
  .web-mock .bm-metrics li {
    position: relative;
    padding-left: 24px;
    font-size: 14px;
    font-weight: 600;
    color: var(--ink);
  }
  .web-mock .bm-metrics li::before {
    content: "✓";
    position: absolute;
    left: 0;
    top: -1px;
    width: 17px;
    height: 17px;
    border-radius: 50%;
    background: var(--teal);
    color: #fff;
    font-size: 10px;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  @media (prefers-reduced-motion: reduce) {
    .web-mock .bm-ring-fg { animation: none; stroke-dashoffset: 0; }
  }

  .home-marquee {
    display: flex;
    flex-direction: column;
    gap: 14px;
    padding: 40px 0 8px;
    overflow: hidden;
  }
  .home-marquee .mq-row {
    overflow: hidden;
  }
  .home-marquee .mq-track {
    display: flex;
    gap: 14px;
    width: max-content;
    will-change: transform;
  }
  .home-marquee .mq-tile {
    flex: none;
    width: 360px;
    height: 228px;
    border-radius: 16px;
    overflow: hidden;
    border: 1px solid var(--line);
    background: var(--steel-tint);
    display: block;
  }
  .home-marquee .mq-tile img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.5s var(--ease-rise);
  }
  .home-marquee .mq-tile:hover img {
    transform: scale(1.05);
  }
  @media (max-width: 700px) {
    .home-marquee .mq-tile {
      width: 248px;
      height: 158px;
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .home-marquee .mq-track {
      will-change: auto;
    }
  }
</style>

<script>
  // Scroll-reactive marquee
  (function () {
    const reduce =
      window.matchMedia &&
      window.matchMedia("(prefers-reduced-motion: reduce)").matches;
    if (reduce) return;

    const section = document.getElementById("reel");
    if (!section) return;

    const rows = Array.from(
      section.querySelectorAll<HTMLElement>(".mq-row")
    ).map((row) => ({
      track: row.querySelector<HTMLElement>(".mq-track")!,
      dir: Number(row.dataset.dir) || 1,
      loop: 0,
    }));

    function measure() {
      rows.forEach((r) => {
        r.loop = r.track.scrollWidth / 3;
      });
    }
    measure();
    window.addEventListener("resize", measure);

    function update() {
      const rect = section.getBoundingClientRect();
      const offset = (window.innerHeight - rect.top) * 0.18;
      rows.forEach((r) => {
        if (!r.loop) return;
        const x = (((r.dir * offset) % r.loop) + r.loop) % r.loop;
        r.track.style.transform = `translate3d(${
          r.dir > 0 ? x - r.loop : -x
        }px,0,0)`;
      });
    }

    let ticking = false;
    function onScroll() {
      if (ticking) return;
      ticking = true;
      requestAnimationFrame(() => {
        update();
        ticking = false;
      });
    }
    update();
    window.addEventListener("scroll", onScroll, { passive: true });
    window.addEventListener("resize", onScroll);
  })();
</script>

<script>
  (function () {
    const els = document.querySelectorAll<HTMLElement>(".reveal");
    if (window.matchMedia && window.matchMedia("(prefers-reduced-motion: reduce)").matches)
      return;
    els.forEach((el) => el.classList.add("armed"));
    const io = new IntersectionObserver(
      (entries) => {
        entries.forEach((e) => {
          if (e.isIntersecting) {
            e.target.classList.add("in");
            io.unobserve(e.target);
          }
        });
      },
      { threshold: 0.12, rootMargin: "0px 0px -6% 0px" }
    );
    els.forEach((el) => io.observe(el));
    setTimeout(() => {
      els.forEach((el) => {
        if (!el.classList.contains("in")) el.classList.add("in");
      });
    }, 1200);
  })();
</script>
