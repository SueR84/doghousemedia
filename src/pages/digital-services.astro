---
import Layout from "../layouts/Layout.astro";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";

const services = [
  { title: "CRM Integration", body: "Seamless connectivity between your customer relationship management software and other third-party applications — your website and office systems finally talking to each other." },
  { title: "Email Marketing", body: "We handle campaigns end to end on HighLevel and Mailchimp, managing your lists and campaigns so the right message reaches the right people." },
  { title: "AI Support Bots", body: "Advanced conversational AI that automates customer interactions across Facebook, Instagram and your own website — answering questions around the clock." },
  { title: "Workflow Automation", body: "Using HighLevel to streamline business processes — automating repetitive tasks, improving efficiency and cutting out manual errors." },
  { title: "Zapier Configuration", body: "We connect your web apps and configure automation across your workflow, so data flows between tools without anyone copying and pasting." },
  { title: "SEO Auditing", body: "A deep analysis of your website to identify SEO errors and keyword opportunities, and to assess what your competitors are doing well." },
  { title: "Consultancy for Studio Creatives", body: "Workflow practices and CRM integration with creative systems like VSCO, delivered through a clear-eyed process audit." },
  { title: "Lead Generation", body: "We turn your website into a marketing tool — supporting online bookings, email campaigns and the engagement that converts visitors into customers." },
];
---

<Layout title="Digital Services — Doghouse Media" description="Digital services from Doghouse Media: CRM integration, email marketing, AI support bots, workflow automation, SEO auditing and lead generation. 20+ years of IT experience in Ireland.">
  <Nav />

  <main>
    <!-- Hero -->
    <section class="ds-hero">
      <div class="wrap">
        <span class="eyebrow">Digital · Services</span>
        <h1>Digital services.</h1>
        <p class="ds-lead">
          With 20-plus years of experience in the IT industry in Ireland, we help you
          connect the tools, automate the busywork and turn your website into a system
          that actually grows the business. Let's book a strategy call.
        </p>
        <div class="ds-actions">
          <a href="mailto:susan@doghousemedia.ie?subject=Strategy%20Call" class="btn btn-primary">Book a strategy call</a>
          <a href="#services" class="btn btn-ghost">See what we do</a>
        </div>
      </div>
    </section>

    <!-- Services -->
    <section class="ds-section reveal" id="services">
      <div class="wrap">
        <span class="kicker">What we offer</span>
        <h2 class="ds-h2">Smarter systems, less busywork.</h2>
        <div class="ds-grid">
          {
            services.map((s, i) => (
              <div class="ds-card">
                <span class="ds-num">{String(i + 1).padStart(2, "0")}</span>
                <h3>{s.title}</h3>
                <p>{s.body}</p>
              </div>
            ))
          }
        </div>
      </div>
    </section>

    <!-- CTA band -->
    <section class="wrap cta-wrap">
      <div class="cta reveal">
        <div class="cta-inner">
          <h2>Have a project? <span class="red">Let's talk.</span></h2>
          <p>Tell us what you're trying to connect, automate or grow — we'll tell you how.</p>
          <a href="mailto:susan@doghousemedia.ie" class="btn btn-cream">Contact us</a>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</Layout>

<style>
  .ds-hero {
    padding: 80px 0 56px;
  }
  .ds-hero h1 {
    font-family: var(--disp);
    font-weight: 800;
    font-size: clamp(38px, 5.6vw, 72px);
    letter-spacing: -0.045em;
    line-height: 1;
    margin: 14px 0 24px;
  }
  .ds-lead {
    font-size: clamp(17px, 1.8vw, 20px);
    max-width: 56ch;
    opacity: 0.78;
    line-height: 1.55;
  }
  .ds-actions {
    display: flex;
    gap: 14px;
    margin-top: 36px;
    flex-wrap: wrap;
  }

  .ds-section {
    padding: 64px 0;
    border-top: 1px solid var(--line);
  }
  .ds-h2 {
    font-family: var(--disp);
    font-weight: 800;
    font-size: clamp(26px, 3.4vw, 42px);
    letter-spacing: -0.04em;
    line-height: 1.04;
    margin: -28px 0 44px;
    max-width: 20ch;
  }
  .ds-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 26px;
  }
  .ds-card {
    border: 1px solid var(--line);
    border-radius: 12px;
    padding: 26px 24px 28px;
    background: #fff;
    transition: transform 0.25s, box-shadow 0.25s, border-color 0.25s;
  }
  .ds-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 18px 40px rgba(15, 20, 23, 0.08);
    border-color: var(--steel);
  }
  .ds-num {
    font-family: var(--mono);
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.1em;
    color: var(--teal);
    display: block;
    margin-bottom: 14px;
  }
  .ds-card h3 {
    font-family: var(--disp);
    font-weight: 700;
    font-size: 19px;
    letter-spacing: -0.025em;
    margin-bottom: 9px;
  }
  .ds-card p {
    font-size: 14px;
    line-height: 1.6;
    opacity: 0.74;
  }

  @media (max-width: 980px) {
    .ds-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  @media (max-width: 560px) {
    .ds-grid {
      grid-template-columns: 1fr;
    }
  }
</style>

<script>
  (function () {
    const els = document.querySelectorAll<HTMLElement>(".reveal");
    if (window.matchMedia && window.matchMedia("(prefers-reduced-motion: reduce)").matches)
      return;
    els.forEach((el) => el.classList.add("armed"));
    const io = new IntersectionObserver(
      (entries) => {
        entries.forEach((e) => {
          if (e.isIntersecting) {
            e.target.classList.add("in");
            io.unobserve(e.target);
          }
        });
      },
      { threshold: 0.12, rootMargin: "0px 0px -6% 0px" }
    );
    els.forEach((el) => io.observe(el));
    setTimeout(() => {
      els.forEach((el) => {
        if (!el.classList.contains("in")) el.classList.add("in");
      });
    }, 1200);
  })();
</script>
