---
// Multi-step "Start a project" modal. Opened by any element with [data-start-project].
// Submits collected enquiry as JSON to /api/enquiry; falls back to a pre-filled
// mailto: handoff if that endpoint isn't live yet (see src/pages/api/enquiry.ts.example).
const enquiryEmail = "hello@doghousemedia.ie";
---

<dialog class="sp-modal" id="start-project" aria-label="Start a project">
  <div class="sp-shell">
    <button type="button" class="sp-close" data-sp-close aria-label="Close">&times;</button>

    <!-- Progress -->
    <div class="sp-progress" data-sp-progress>
      <span class="sp-step-dot" data-dot="1"></span>
      <span class="sp-step-dot" data-dot="2"></span>
      <span class="sp-step-dot" data-dot="3"></span>
      <span class="sp-step-dot" data-dot="4"></span>
    </div>

    <form class="sp-form" novalidate>
      <!-- STEP 1 — Track -->
      <section class="sp-panel" data-panel="1">
        <span class="sp-kicker">Start a project</span>
        <h2 class="sp-title">What can we help you build?</h2>
        <p class="sp-sub">Pick a track and we'll ask the right questions.</p>
        <div class="sp-choice-grid">
          <button type="button" class="sp-choice" data-track="web">
            <span class="sp-choice-tag">Web</span>
            <span class="sp-choice-name">Website or web app</span>
            <span class="sp-choice-desc">Custom sites, redesigns, e-commerce & platforms.</span>
          </button>
          <button type="button" class="sp-choice" data-track="video">
            <span class="sp-choice-tag blue">Video</span>
            <span class="sp-choice-name">Film or video</span>
            <span class="sp-choice-desc">Brand films, promos, event & social content.</span>
          </button>
        </div>
      </section>

      <!-- STEP 2 — Project details -->
      <section class="sp-panel" data-panel="2" hidden>
        <span class="sp-kicker" data-track-label>Web project</span>
        <h2 class="sp-title">Tell us about the project.</h2>

        <!-- Web fields -->
        <div class="sp-track-fields" data-fields="web">
          <label class="sp-field">
            <span class="sp-label">Project type</span>
            <select name="web_type">
              <option value="">Select…</option>
              <option>New website</option>
              <option>Redesign</option>
              <option>E-commerce</option>
              <option>Web app / platform</option>
            </select>
          </label>
          <div class="sp-row">
            <label class="sp-field">
              <span class="sp-label">Approx. pages</span>
              <select name="web_pages">
                <option value="">Select…</option>
                <option>1–5</option>
                <option>6–15</option>
                <option>16–40</option>
                <option>40+</option>
              </select>
            </label>
            <label class="sp-field">
              <span class="sp-label">Need a CMS?</span>
              <select name="web_cms">
                <option value="">Select…</option>
                <option>Yes — I'll edit it myself</option>
                <option>No</option>
                <option>Not sure</option>
              </select>
            </label>
          </div>
        </div>

        <!-- Video fields -->
        <div class="sp-track-fields" data-fields="video" hidden>
          <label class="sp-field">
            <span class="sp-label">Video type</span>
            <select name="video_type">
              <option value="">Select…</option>
              <option>Brand film</option>
              <option>Promo / advert</option>
              <option>Event coverage</option>
              <option>Social content</option>
            </select>
          </label>
          <div class="sp-row">
            <label class="sp-field">
              <span class="sp-label">Approx. length</span>
              <select name="video_length">
                <option value="">Select…</option>
                <option>Under 30s</option>
                <option>30s–2 min</option>
                <option>2–5 min</option>
                <option>5 min+</option>
              </select>
            </label>
            <label class="sp-field">
              <span class="sp-label">Where will it run?</span>
              <select name="video_usage">
                <option value="">Select…</option>
                <option>Website</option>
                <option>Social media</option>
                <option>TV / broadcast</option>
                <option>Internal / events</option>
              </select>
            </label>
          </div>
        </div>

        <label class="sp-field">
          <span class="sp-label">Describe what you have in mind</span>
          <textarea name="description" rows="4" placeholder="A few sentences about your goals, audience, and anything that matters."></textarea>
        </label>
      </section>

      <!-- STEP 3 — Budget & timeline -->
      <section class="sp-panel" data-panel="3" hidden>
        <span class="sp-kicker">Budget &amp; timeline</span>
        <h2 class="sp-title">What are we working with?</h2>
        <p class="sp-sub">Ballpark is fine — it helps us scope the right approach.</p>

        <span class="sp-label">Budget</span>
        <div class="sp-chips" data-chips="budget">
          <button type="button" class="sp-chip" data-value="< €2.5k">&lt; €2.5k</button>
          <button type="button" class="sp-chip" data-value="€2.5–5k">€2.5–5k</button>
          <button type="button" class="sp-chip" data-value="€5–10k">€5–10k</button>
          <button type="button" class="sp-chip" data-value="€10k+">€10k+</button>
        </div>

        <span class="sp-label sp-label-gap">Timeline</span>
        <div class="sp-chips" data-chips="timeline">
          <button type="button" class="sp-chip" data-value="ASAP">ASAP</button>
          <button type="button" class="sp-chip" data-value="1–3 months">1–3 months</button>
          <button type="button" class="sp-chip" data-value="3–6 months">3–6 months</button>
          <button type="button" class="sp-chip" data-value="Flexible">Flexible</button>
        </div>
      </section>

      <!-- STEP 4 — Contact -->
      <section class="sp-panel" data-panel="4" hidden>
        <span class="sp-kicker">Almost there</span>
        <h2 class="sp-title">Where can we reach you?</h2>
        <div class="sp-row">
          <label class="sp-field">
            <span class="sp-label">Name *</span>
            <input type="text" name="name" autocomplete="name" required />
          </label>
          <label class="sp-field">
            <span class="sp-label">Email *</span>
            <input type="email" name="email" autocomplete="email" required />
          </label>
        </div>
        <div class="sp-row">
          <label class="sp-field">
            <span class="sp-label">Company</span>
            <input type="text" name="company" autocomplete="organization" />
          </label>
          <label class="sp-field">
            <span class="sp-label">Phone</span>
            <input type="tel" name="phone" autocomplete="tel" />
          </label>
        </div>
        <p class="sp-error" data-sp-error hidden></p>
      </section>

      <!-- SUCCESS -->
      <section class="sp-panel sp-success" data-panel="done" hidden>
        <div class="sp-check" aria-hidden="true">&checkmark;</div>
        <h2 class="sp-title">Thanks — we're on it.</h2>
        <p class="sp-sub">
          Your enquiry is on its way. We'll be in touch within one working day.
        </p>
        <button type="button" class="btn btn-primary" data-sp-close>Done</button>
      </section>

      <!-- Footer nav -->
      <div class="sp-nav" data-sp-foot>
        <button type="button" class="sp-back" data-sp-back hidden>&larr; Back</button>
        <button type="button" class="btn btn-primary sp-next" data-sp-next hidden>Continue</button>
        <button type="submit" class="btn btn-primary sp-submit" data-sp-submit hidden>Send enquiry</button>
      </div>
    </form>
  </div>
</dialog>

<style>
  .sp-modal {
    border: none;
    border-radius: 16px;
    padding: 0;
    margin: auto;
    width: min(620px, calc(100vw - 32px));
    max-height: calc(100dvh - 48px);
    background: var(--cream);
    color: var(--ink);
    box-shadow: 0 30px 80px rgba(0, 0, 0, 0.35);
    overflow: hidden;
  }
  .sp-modal::backdrop {
    background: rgba(15, 15, 15, 0.55);
    backdrop-filter: blur(3px);
  }
  .sp-modal[open] {
    animation: sp-pop 0.22s cubic-bezier(0.2, 0.7, 0.3, 1);
  }
  @keyframes sp-pop {
    from { opacity: 0; transform: translateY(8px) scale(0.985); }
    to { opacity: 1; transform: none; }
  }
  .sp-shell {
    position: relative;
    padding: 40px;
    max-height: calc(100dvh - 48px);
    overflow-y: auto;
  }

  .sp-close {
    position: absolute;
    top: 16px;
    right: 18px;
    border: none;
    background: transparent;
    font-size: 28px;
    line-height: 1;
    color: var(--gray);
    cursor: pointer;
    padding: 4px;
    transition: color 0.15s;
  }
  .sp-close:hover { color: var(--ink); }

  .sp-progress {
    display: flex;
    gap: 8px;
    margin-bottom: 28px;
  }
  .sp-step-dot {
    height: 4px;
    flex: 1;
    border-radius: 99px;
    background: var(--line);
    transition: background 0.25s;
  }
  .sp-step-dot.active { background: var(--ink); }
  .sp-step-dot.done { background: var(--red); }

  .sp-kicker {
    font-family: var(--mono);
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--red);
    display: block;
    margin-bottom: 10px;
  }
  .sp-title {
    font-family: var(--disp);
    font-weight: 800;
    font-size: clamp(22px, 3.5vw, 30px);
    letter-spacing: -0.03em;
    line-height: 1.1;
  }
  .sp-sub {
    font-size: 15px;
    line-height: 1.55;
    opacity: 0.72;
    margin-top: 10px;
  }

  /* Track choice */
  .sp-choice-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
    margin-top: 28px;
  }
  .sp-choice {
    display: flex;
    flex-direction: column;
    gap: 8px;
    text-align: left;
    padding: 24px;
    border-radius: 12px;
    border: 1.5px solid var(--line);
    background: #fff;
    cursor: pointer;
    transition: border-color 0.18s, transform 0.18s, box-shadow 0.18s;
  }
  .sp-choice:hover {
    border-color: var(--ink);
    transform: translateY(-2px);
    box-shadow: 0 10px 28px rgba(0, 0, 0, 0.08);
  }
  .sp-choice-tag {
    font-family: var(--mono);
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--red);
  }
  .sp-choice-tag.blue { color: var(--teal); }
  .sp-choice-name {
    font-family: var(--disp);
    font-weight: 700;
    font-size: 18px;
    letter-spacing: -0.02em;
  }
  .sp-choice-desc {
    font-size: 13px;
    line-height: 1.5;
    opacity: 0.7;
  }

  /* Fields */
  .sp-field {
    display: flex;
    flex-direction: column;
    gap: 7px;
    margin-top: 18px;
    flex: 1;
  }
  .sp-row {
    display: flex;
    gap: 16px;
  }
  .sp-label {
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--gray);
    display: block;
  }
  .sp-label-gap { margin-top: 24px; }
  .sp-field input,
  .sp-field select,
  .sp-field textarea {
    font-family: var(--body);
    font-size: 15px;
    color: var(--ink);
    background: #fff;
    border: 1.5px solid var(--line);
    border-radius: 8px;
    padding: 11px 13px;
    width: 100%;
    transition: border-color 0.15s;
  }
  .sp-field textarea { resize: vertical; }
  .sp-field input:focus,
  .sp-field select:focus,
  .sp-field textarea:focus {
    outline: none;
    border-color: var(--ink);
  }
  .sp-field input.invalid { border-color: var(--red); }

  /* Chips */
  .sp-chips {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    margin-top: 10px;
  }
  .sp-chip {
    font-family: var(--body);
    font-size: 14px;
    font-weight: 600;
    padding: 10px 18px;
    border-radius: 99px;
    border: 1.5px solid var(--line);
    background: #fff;
    color: var(--ink);
    cursor: pointer;
    transition: all 0.15s;
  }
  .sp-chip:hover { border-color: var(--ink); }
  .sp-chip.selected {
    background: var(--ink);
    color: var(--cream);
    border-color: var(--ink);
  }

  /* Nav */
  .sp-nav {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-top: 32px;
  }
  .sp-back {
    font-family: var(--body);
    font-size: 14px;
    font-weight: 600;
    background: transparent;
    border: none;
    color: var(--gray);
    cursor: pointer;
    padding: 8px 4px;
    transition: color 0.15s;
  }
  .sp-back:hover { color: var(--ink); }
  .sp-next,
  .sp-submit { margin-left: auto; }
  .sp-next:disabled,
  .sp-submit:disabled { opacity: 0.4; cursor: not-allowed; }
  /* The global .btn rule sets display:inline-block, which would override the
     hidden attribute — force hidden buttons to stay hidden. */
  .sp-nav [hidden],
  .sp-panel[hidden] { display: none !important; }

  .sp-error {
    color: var(--red);
    font-size: 13px;
    margin-top: 14px;
  }

  /* Success */
  .sp-success { text-align: center; padding: 20px 0; }
  .sp-check {
    width: 64px;
    height: 64px;
    margin: 0 auto 20px;
    border-radius: 50%;
    background: var(--red);
    color: var(--cream);
    font-size: 32px;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .sp-success .btn { margin-top: 24px; }

  @media (max-width: 560px) {
    .sp-shell { padding: 28px 22px; }
    .sp-choice-grid,
    .sp-row { grid-template-columns: 1fr; flex-direction: column; }
  }

  @media (prefers-reduced-motion: reduce) {
    .sp-modal[open] { animation: none; }
    .sp-choice:hover { transform: none; }
  }
</style>

<script define:vars={{ enquiryEmail }}>
  (function () {
    const dialog = document.getElementById("start-project");
    if (!dialog) return;

    const form = dialog.querySelector(".sp-form");
    const dots = dialog.querySelectorAll(".sp-step-dot");
    const backBtn = dialog.querySelector("[data-sp-back]");
    const nextBtn = dialog.querySelector("[data-sp-next]");
    const submitBtn = dialog.querySelector("[data-sp-submit]");
    const foot = dialog.querySelector("[data-sp-foot]");
    const progress = dialog.querySelector("[data-sp-progress]");
    const errorEl = dialog.querySelector("[data-sp-error]");

    const data = { track: "", budget: "", timeline: "" };
    let step = 1; // 1..4, then "done"

    function panel(name) {
      return dialog.querySelector(`[data-panel="${name}"]`);
    }
    function showPanel(name) {
      dialog
        .querySelectorAll(".sp-panel")
        .forEach((p) => (p.hidden = p.dataset.panel !== String(name)));
    }

    function render() {
      showPanel(step);
      progress.hidden = step === "done";
      foot.hidden = step === "done" || step === 1;

      dots.forEach((d, i) => {
        const n = i + 1;
        d.classList.toggle("active", typeof step === "number" && n === step);
        d.classList.toggle("done", typeof step === "number" && n < step);
      });

      backBtn.hidden = step === 1;
      nextBtn.hidden = step === 1 || step >= 4;
      submitBtn.hidden = step !== 4;
      if (errorEl) errorEl.hidden = true;
    }

    function open() {
      step = 1;
      render();
      if (typeof dialog.showModal === "function") dialog.showModal();
      else dialog.setAttribute("open", "");
    }
    function close() {
      if (typeof dialog.close === "function") dialog.close();
      else dialog.removeAttribute("open");
    }

    // Open triggers
    document.querySelectorAll("[data-start-project]").forEach((btn) => {
      btn.addEventListener("click", (e) => {
        e.preventDefault();
        open();
      });
    });

    // Close triggers
    dialog.querySelectorAll("[data-sp-close]").forEach((b) =>
      b.addEventListener("click", close)
    );
    dialog.addEventListener("click", (e) => {
      // backdrop click (clicks land on the dialog element itself)
      if (e.target === dialog) close();
    });

    // Track choice
    dialog.querySelectorAll("[data-track]").forEach((b) => {
      b.addEventListener("click", () => {
        data.track = b.dataset.track;
        const isWeb = data.track === "web";
        dialog.querySelector('[data-fields="web"]').hidden = !isWeb;
        dialog.querySelector('[data-fields="video"]').hidden = isWeb;
        dialog.querySelector("[data-track-label]").textContent = isWeb
          ? "Web project"
          : "Video project";
        step = 2;
        render();
      });
    });

    // Chips
    dialog.querySelectorAll("[data-chips]").forEach((group) => {
      group.querySelectorAll(".sp-chip").forEach((chip) => {
        chip.addEventListener("click", () => {
          group
            .querySelectorAll(".sp-chip")
            .forEach((c) => c.classList.remove("selected"));
          chip.classList.add("selected");
          data[group.dataset.chips] = chip.dataset.value;
        });
      });
    });

    backBtn.addEventListener("click", () => {
      if (typeof step === "number" && step > 1) {
        step -= 1;
        render();
      }
    });
    nextBtn.addEventListener("click", () => {
      if (typeof step === "number" && step < 4) {
        step += 1;
        render();
      }
    });

    function collect() {
      const fd = new FormData(form);
      const payload = { track: data.track, budget: data.budget, timeline: data.timeline };
      for (const [k, v] of fd.entries()) {
        if (v) payload[k] = v;
      }
      return payload;
    }

    function asText(p) {
      return Object.entries(p)
        .map(([k, v]) => `${k}: ${v}`)
        .join("\n");
    }

    form.addEventListener("submit", async (e) => {
      e.preventDefault();
      const name = form.querySelector('[name="name"]');
      const email = form.querySelector('[name="email"]');
      let ok = true;
      [name, email].forEach((f) => {
        const valid = f.checkValidity() && f.value.trim();
        f.classList.toggle("invalid", !valid);
        if (!valid) ok = false;
      });
      if (!ok) {
        errorEl.textContent = "Please add your name and a valid email.";
        errorEl.hidden = false;
        return;
      }

      const payload = collect();
      submitBtn.disabled = true;
      submitBtn.textContent = "Sending…";

      try {
        const res = await fetch("/api/enquiry", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify(payload),
        });
        if (!res.ok) throw new Error("Bad response");
      } catch (err) {
        // Endpoint not live yet — fall back to a pre-filled email handoff.
        const subject = `New ${payload.track || "project"} enquiry — ${payload.name}`;
        const body = asText(payload);
        window.location.href = `mailto:${enquiryEmail}?subject=${encodeURIComponent(
          subject
        )}&body=${encodeURIComponent(body)}`;
      } finally {
        submitBtn.disabled = false;
        submitBtn.textContent = "Send enquiry";
        step = "done";
        render();
      }
    });

    dialog.addEventListener("close", () => {
      step = 1;
    });
  })();
</script>
