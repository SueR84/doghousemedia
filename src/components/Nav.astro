---
import Mark from "./Mark.astro";

const links = [
  { label: "Work", href: "/work/" },
  { label: "Video", href: "/media-production/" },
  { label: "Web", href: "/web-development/" },
  { label: "Digital", href: "/digital-services/" },
  { label: "Studio", href: "/about/" },
];
---

<nav>
  <div class="wrap nav-inner">
    <a href="/" class="logo-lockup">
      <Mark size={38} />
      <span class="logo-word">Doghouse Media</span>
    </a>
    <div class="nav-links">
      {links.map((l) => <a href={l.href}>{l.label}</a>)}
      <button type="button" class="nav-cta" data-start-project>Start a project</button>
    </div>
  </div>
</nav>
